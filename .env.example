# =============================================================================
# KAK FIT — Environment Variables
# Full guide: docs/ENV_SETUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Local Development
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Local (Docker): use as-is after `pnpm docker:up`
# Production: postgresql://USER:PASSWORD@HOST:5432/kak_fit?schema=public&sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kak_fit?schema=public"

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Next.js server port
PORT=3000

# Expo mobile app — API base URL
# Local simulator: http://localhost:3000
# Physical device: http://YOUR_LAN_IP:3000
# Production: https://api.kakfit.app
EXPO_PUBLIC_API_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# REQUIRED — Nutrition (USDA FoodData Central, free API key)
# Get key: https://fdc.nal.usda.gov/api-key-signup.html
# -----------------------------------------------------------------------------
USDA_API_KEY=""

# -----------------------------------------------------------------------------
# OPTIONAL — Google OAuth (leave empty for email-only auth)
# Get from: https://console.cloud.google.com → Credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# OPTIONAL — File Storage (Phase 2+)
# Option A: Self-hosted MinIO (recommended, $0)
# -----------------------------------------------------------------------------
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="kak-fit"
S3_REGION="us-east-1"
S3_PUBLIC_URL=""

# Option B: Supabase Storage (free tier 1GB)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# -----------------------------------------------------------------------------
# OPTIONAL — Payments (Phase 3+, Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# -----------------------------------------------------------------------------
# OPTIONAL — Push Notifications (Phase 3+)
# Get from: https://expo.dev → Access Tokens
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=""
