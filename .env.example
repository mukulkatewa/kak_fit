# =============================================================================
# KAK FIT — Environment Variables
# Full guide: docs/ENV_SETUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Local Development
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Local (Docker): use as-is after `pnpm docker:up`
# Supabase: set password + pooler host from Dashboard → Connect → Prisma
# Pool params (optional — also set via env vars below):
#   ?schema=public&connection_limit=15&pool_timeout=20
SUPABASE_PROJECT_REF=""
SUPABASE_DB_PASSWORD=""
SUPABASE_POOLER_HOST="aws-1-ap-northeast-1.pooler.supabase.com"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kak_fit?schema=public&connection_limit=15&pool_timeout=20"
DIRECT_URL=""
# Production (Vercel): set PRISMA_ACCELERATE_URL from https://console.prisma.io → Accelerate
# sync:ip writes DATABASE_URL from this and keeps DIRECT_URL on the Supabase pooler.
PRISMA_ACCELERATE_URL=""

# Prisma connection pool (applied when not already in DATABASE_URL)
DATABASE_POOL_TIMEOUT=20
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_LIMIT=15

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Next.js server port
PORT=3000

# Expo mobile app — API base URL
# Local simulator: http://localhost:3000
# Physical device: http://YOUR_LAN_IP:3000
# Production: https://api.kakfit.app
EXPO_PUBLIC_API_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# REQUIRED — Nutrition (USDA FoodData Central, free API key)
# Get key: https://fdc.nal.usda.gov/api-key-signup.html
# -----------------------------------------------------------------------------
USDA_API_KEY=""

# -----------------------------------------------------------------------------
# REQUIRED — Google OAuth (Sign in with Google)
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Redirect URIs: https://api.kakfit.app/api/auth/callback/google
#               http://localhost:3000/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# OPTIONAL — File Storage (Phase 2+)
# Option A: Self-hosted MinIO (recommended, $0)
# -----------------------------------------------------------------------------
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="kak-fit"
S3_REGION="us-east-1"
S3_PUBLIC_URL=""

# Supabase (production database + storage)
# Pooler host: Dashboard → Connect → Prisma (e.g. aws-1-ap-northeast-1.pooler.supabase.com)
SUPABASE_PROJECT_REF=""
SUPABASE_DB_PASSWORD=""
SUPABASE_POOLER_HOST=""
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci...anon-jwt-from-dashboard"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci...service-role-jwt-from-dashboard"
# Progress-photo storage bucket (auto-created public on first upload)
SUPABASE_STORAGE_BUCKET="progress-photos"


# -----------------------------------------------------------------------------
# OPTIONAL — Daily exercise reminder emails (Resend + React Email)
# Run with: pnpm send:daily-reminders
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
# Must be a verified Resend sender, e.g. Kak Fit <workouts@yourdomain.com>
RESEND_FROM_EMAIL=""
# Deep link or web app URL used in the reminder CTA
EXERCISE_REMINDER_APP_URL="kakfit://"
EXERCISE_REMINDER_BATCH_SIZE=500
EXERCISE_REMINDER_CONCURRENCY=5
# Required in production for /api/jobs/daily-exercise-reminders
CRON_SECRET=""

# -----------------------------------------------------------------------------
# OPTIONAL — Payments (Phase 3+, Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# -----------------------------------------------------------------------------
# OPTIONAL — Push Notifications (Phase 3+)
# Get from: https://expo.dev → Access Tokens
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=""

# -----------------------------------------------------------------------------
# OPTIONAL — Hevy Pro API (one-off import scripts only, NOT used by the app)
# Get from: https://hevy.com/settings?developer
# Used by: pnpm import:hevy, pnpm import:hevy:test
# -----------------------------------------------------------------------------
HEVY_API_KEY=""
