{
  "name": "@kak-fit/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "bash ../../scripts/start-expo.sh",
    "start:tunnel": "expo start --tunnel --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port 8081",
    "export:web": "expo export -p web --output-dir ../web/public",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/**/*.test.ts",
    "build:preview": "eas build --profile preview --non-interactive",
    "build:android": "eas build --platform android --profile preview --non-interactive",
    "build:ios": "eas build --platform ios --profile preview --non-interactive",
    "build:production": "eas build --profile production --non-interactive"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.22",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@kak-fit/api": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-navigation/native": "^7.3.3",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.2",
    "@trpc/react-query": "^11.0.2",
    "@types/react-dom": "^19.1.11",
    "better-auth": "^1.6.22",
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.12",
    "expo-network": "^56.0.5",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.9",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "^56.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-heroicons": "^4.0.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "superjson": "^2.2.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "~19.1.17",
    "babel-preset-expo": "~54.0.11",
    "eas-cli": "^20.4.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3"
  }
}
