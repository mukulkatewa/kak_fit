{
  "name": "kak_fit",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter @kak-fit/web dev",
    "dev:web-app": "pnpm --filter @kak-fit/mobile web",
    "export:web": "pnpm --filter @kak-fit/mobile export:web",
    "dev:api": "bash scripts/start-api.sh",
    "dev:mobile": "bash scripts/start-expo.sh",
    "build:mobile": "bash scripts/build-mobile.sh",
    "build:mobile:ios": "bash scripts/build-mobile.sh ios",
    "build:mobile:prod": "bash scripts/build-mobile.sh production android",
    "sync:ip": "bash scripts/sync-ip.sh",
    "reinstall": "bash scripts/reinstall-deps.sh",
    "kill:ports": "fuser -k 3000/tcp 3001/tcp 8081/tcp 2>/dev/null || true",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:import": "pnpm --filter @kak-fit/db import:wger",
    "import:hevy": "pnpm --filter @kak-fit/db import:hevy",
    "import:hevy:force": "pnpm --filter @kak-fit/db import:hevy:force",
    "merge:hevy": "pnpm --filter @kak-fit/db merge:hevy",
    "backfill:hevy-categories": "pnpm --filter @kak-fit/db backfill:hevy-categories",
    "import:hevy:test": "pnpm --filter @kak-fit/db import:hevy:test",
    "update:hevy": "pnpm --filter @kak-fit/db update:hevy",
    "verify:hevy": "pnpm --filter @kak-fit/db verify:hevy",
    "analyze:hevy": "pnpm --filter @kak-fit/db analyze:hevy",
    "db:seed": "pnpm --filter @kak-fit/db seed:demo",
    "db:count": "pnpm --filter @kak-fit/db count",
    "db:studio": "pnpm --filter @kak-fit/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
