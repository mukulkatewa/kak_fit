{
  "name": "@kak-fit/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.types.ts",
    "./public-api": "./src/public-api/index.ts",
