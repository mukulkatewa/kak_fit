{
  "name": "@kak-fit/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "dotenv -o -e ../../.env -- prisma generate",
    "db:push": "dotenv -o -e ../../.env -- prisma db push --accept-data-loss",
    "studio": "dotenv -o -e ../../.env -- prisma studio",
    "import:wger": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/import-wger.ts'",
    "import:hevy": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/import-hevy-exercises.ts'",
    "import:hevy:force": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/import-hevy-exercises.ts -- --force'",
    "merge:hevy": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/merge-hevy-catalog.ts'",
    "backfill:hevy-categories": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/backfill-hevy-categories.ts'",
    "import:hevy:test": "dotenv -o -e ../../.env -- tsx scripts/hevy/test-hevy-api.ts",
    "import:hevy:dry": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/import-hevy-exercises.ts -- --dry-run'",
    "update:hevy": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/update-hevy-exercises.ts'",
    "analyze:hevy": "dotenv -o -e ../../.env -- tsx scripts/hevy/analyze-hevy-schema.ts",
    "verify:hevy": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/hevy/verify-hevy-import.ts'",
    "seed:demo": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/seed-demo.ts'",
    "count": "dotenv -o -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/count.ts'"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@prisma/extension-accelerate": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "better-auth": "^1.6.22",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
