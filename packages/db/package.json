{
  "name": "@kak-fit/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "import:wger": "dotenv -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/import-wger.ts'",
    "seed:demo": "dotenv -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/seed-demo.ts'",
    "count": "dotenv -e ../../.env -- bash -c 'DATABASE_URL=\"$DIRECT_URL\" tsx scripts/count.ts'"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "better-auth": "^1.2.8",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
