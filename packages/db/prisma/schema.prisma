generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionTier {
  FREE
  PRO
}

enum SetType {
  NORMAL
  WARMUP
  DROP
  FAILURE
}

enum PersonalRecordType {
  MAX_WEIGHT
  MAX_REPS
  MAX_VOLUME
  ESTIMATED_1RM
  MAX_DURATION
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum WeightUnit {
  KG
  LBS
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  emailVerified    Boolean          @default(false)
  image            String?
  bio              String?
  isPrivate        Boolean          @default(false)
  subscriptionTier SubscriptionTier @default(FREE)
  calorieGoal          Int?
  proteinGoal          Int?
  carbGoal             Int?
  fatGoal              Int?
  weightUnit           WeightUnit @default(KG)
  defaultRestSeconds   Int        @default(90)
  createdAt            DateTime   @default(now())
  updatedAt        DateTime         @updatedAt

  sessions         Session[]
  accounts         Account[]
  routines         Routine[]
  routineFolders   RoutineFolder[]
  workouts         Workout[]
  customExercises  Exercise[]       @relation("CustomExercises")
  followers        Follow[]         @relation("Following")
  following        Follow[]         @relation("Followers")
  likes            Like[]
  comments         Comment[]
  personalRecords  PersonalRecord[]
  bodyMeasurements BodyMeasurement[]
  mealLogs         MealLog[]
  customFoods      Food[]           @relation("CustomFoods")
  progressPhotos   ProgressPhoto[]
  apiKeys          ApiKey[]
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String    @default("Default")
  keyPrefix  String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WorkoutDeletionLog {
  id        String   @id @default(cuid())
  userId    String
  workoutId String
  deletedAt DateTime @default(now())

  @@index([userId, deletedAt])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  workoutId String?
  url       String
  path      String
  note      String?
  weight    Float?
  takenAt   DateTime @default(now())
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@index([userId, takenAt])
  @@index([workoutId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Muscle {
  id     String @id @default(cuid())
  name   String
  wgerId Int?   @unique

  exercises ExerciseMuscle[]
}

model Equipment {
  id     String @id @default(cuid())
  name   String
  wgerId Int?   @unique

  exercises ExerciseEquipment[]
}

model Category {
  id     String @id @default(cuid())
  name   String
  wgerId Int?   @unique

  exercises Exercise[]
}

model Exercise {
  id           String   @id @default(cuid())
  name         String
  instructions String?
  imageUrl     String?
  videoUrl     String?
  wgerId       Int?     @unique
  hevyId       String?  @unique
  hevyUpdatedAt DateTime?
  isCustom     Boolean  @default(false)
  userId       String?
  categoryId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User?               @relation("CustomExercises", fields: [userId], references: [id], onDelete: Cascade)
  category         Category?           @relation(fields: [categoryId], references: [id])
  muscles          ExerciseMuscle[]
  equipment        ExerciseEquipment[]
  routineExercises RoutineExercise[]
  workoutExercises WorkoutExercise[]
  personalRecords  PersonalRecord[]

  @@index([isCustom, userId])
  @@index([categoryId, isCustom, userId])
  @@index([name])
}

model ExerciseMuscle {
  id         String  @id @default(cuid())
  exerciseId String
  muscleId   String
  isPrimary  Boolean @default(true)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, muscleId])
}

model ExerciseEquipment {
  id          String @id @default(cuid())
  exerciseId  String
  equipmentId String

  exercise  Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, equipmentId])
}

model RoutineFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  routines Routine[]
}

model Routine {
  id        String   @id @default(cuid())
  userId    String
  folderId  String?
  name       String
  notes      String?
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    RoutineFolder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  exercises RoutineExercise[]

  @@index([userId, updatedAt])
  @@index([userId, folderId, updatedAt])
}

model RoutineExercise {
  id            String @id @default(cuid())
  routineId     String
  exerciseId    String
  order         Int
  restSeconds   Int?
  notes         String?
  supersetGroup Int?

  routine  Routine      @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sets     RoutineSet[]

  @@unique([routineId, order])
}

model RoutineSet {
  id                String  @id @default(cuid())
  routineExerciseId String
  setNumber         Int
  targetWeight      Float?
  targetReps        Int?
  targetDuration    Int?
  setType           SetType @default(NORMAL)

  routineExercise RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)
}

model Workout {
  id         String    @id @default(cuid())
  userId     String
  name       String?
  notes      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  isPublic   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises      WorkoutExercise[]
  likes          Like[]
  comments       Comment[]
  media          Media[]
  progressPhotos ProgressPhoto[]

  @@index([userId, finishedAt(sort: Desc)])
  @@index([userId, startedAt])
  @@index([finishedAt])
}

model WorkoutExercise {
  id            String @id @default(cuid())
  workoutId     String
  exerciseId    String
  order         Int
  restSeconds   Int?
  notes         String?
  supersetGroup Int?

  workout  Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sets     WorkoutSet[]

  @@unique([workoutId, order]) // unique index covers (workoutId, order) for ordered exercise queries
  @@index([workoutId])
  @@index([exerciseId])
  @@index([exerciseId, workoutId])
}

model WorkoutSet {
  id                String  @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  weight            Float?
  reps              Int?
  duration          Int?
  rpe               Float?
  notes             String?
  setType           SetType @default(NORMAL)
  isCompleted       Boolean @default(false)

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  personalRecords PersonalRecord[]

  @@index([workoutExerciseId, setNumber])
  @@index([workoutExerciseId, isCompleted])
  @@index([workoutExerciseId, setNumber, isCompleted])
  @@index([isCompleted])
}

model PersonalRecord {
  id           String             @id @default(cuid())
  userId       String
  exerciseId   String
  workoutSetId String?
  type         PersonalRecordType
  value        Float
  achievedAt   DateTime           @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise   Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutSet WorkoutSet? @relation(fields: [workoutSetId], references: [id], onDelete: SetNull)

  @@index([userId, exerciseId, type])
  @@index([exerciseId, type, value])
  @@index([userId, achievedAt])
}

model BodyMeasurement {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  weight    Float?
  bodyFat   Float?
  waist     Float?
  chest     Float?
  arms      Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  workoutId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@unique([userId, workoutId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  workoutId String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")
}

model Media {
  id        String    @id @default(cuid())
  workoutId String
  url       String
  type      MediaType
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model Food {
  id          String   @id @default(cuid())
  usdaFdcId   Int?     @unique
  name        String
  brand       String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  servingSize Float?   @default(100)
  servingUnit String?  @default("g")
  isCustom    Boolean  @default(false)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User?      @relation("CustomFoods", fields: [userId], references: [id], onDelete: Cascade)
  mealItems MealItem[]

  @@index([name])
}

model MealLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  mealType  MealType @default(LUNCH)
  name      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealItem[]

  @@index([userId, date])
  @@index([userId, mealType, date])
}

model MealItem {
  id       String @id @default(cuid())
  mealId   String
  foodId   String
  quantity Float  @default(100)
  unit     String @default("g")

  meal MealLog @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food    @relation(fields: [foodId], references: [id], onDelete: Cascade)
}
